# ROA OCR API — Variables de entorno
# Copia este archivo a .env y edita según tu configuración

# ── API Keys (separadas por comas) ─────────────────────────────────────────
# CAMBIA ESTO en producción. Puedes poner múltiples keys separadas por coma.
ROA_API_KEYS=roa-dev-key-2024,mi-segunda-key

# ── Motor OCR preferido ─────────────────────────────────────────────────────
# auto     → detecta automáticamente (recomendado)
# acrobat  → usa Adobe Acrobat COM (requiere Acrobat Pro instalado)
# ocrmypdf → usa ocrmypdf + Tesseract
# tesseract → usa pytesseract directamente
ROA_ENGINE=auto

# ── Idioma por defecto ──────────────────────────────────────────────────────
ROA_LANG=spa+eng

# ── Configuración de red ────────────────────────────────────────────────────
ROA_HOST=0.0.0.0
ROA_PORT=8000

# ── Límites ─────────────────────────────────────────────────────────────────
ROA_MAX_MB=100
ROA_THREADS=2
ROA_RETRIES=2
ROA_DPI=300

# ── Opciones de pipeline ─────────────────────────────────────────────────────
ROA_COMPRESS=true
ROA_FIX_ORIENTATION=true
ROA_SPELL_CHECK=false
ROA_SKIP_TEXT=true

# ── Redis (opcional — para cola Celery en producción) ─────────────────────────
# Si no tienes Redis, el sistema usa Threading automáticamente.
ROA_REDIS_URL=redis://localhost:6379/0
ROA_CELERY_CONCURRENCY=2
